#!/bin/bash
# Enhanced claude-code wrapper that adds metadata for better tracking
# 
# Usage: 
#   Instead of: claude-code "your task"
#   Use:        claude-tracked "your task"
#
# Or create an alias in your shell:
#   alias cc='claude-tracked'

# Get the actual task description
TASK="$*"

# Try to detect IDE from environment
if [ -n "$RUBYMINE_VM_OPTIONS" ]; then
    IDE="RubyMine"
elif [ -n "$VSCODE_PID" ]; then
    IDE="VS Code"
elif [ -n "$PYCHARM_VM_OPTIONS" ]; then
    IDE="PyCharm"
else
    # Fallback: detect from parent process
    PARENT_PID=$$
    PARENT_NAME=$(ps -o comm= -p $PPID)
    
    if [[ "$PARENT_NAME" == *"RubyMine"* ]]; then
        IDE="RubyMine"
    elif [[ "$PARENT_NAME" == *"Code"* ]]; then
        IDE="VS Code"
    elif [[ "$PARENT_NAME" == *"PyCharm"* ]]; then
        IDE="PyCharm"
    elif [[ "$PARENT_NAME" == *"Terminal"* ]] || [[ "$PARENT_NAME" == *"iTerm"* ]]; then
        IDE="$PARENT_NAME"
    else
        IDE="Terminal"
    fi
fi

# Create a marker file with metadata (optional - for future enhancements)
TRACKER_DIR="$HOME/.claude-tracker"
mkdir -p "$TRACKER_DIR/metadata"

# Generate unique session ID
SESSION_ID="$(date +%s)_$$"
METADATA_FILE="$TRACKER_DIR/metadata/$SESSION_ID.json"

cat > "$METADATA_FILE" << EOF
{
  "session_id": "$SESSION_ID",
  "task": "$TASK",
  "ide": "$IDE",
  "started_at": $(date +%s),
  "pid": $$,
  "working_dir": "$PWD"
}
EOF

# Run the actual claude-code command
echo "🤖 Starting Claude Code session via $IDE..."
claude-code "$@"

# Record completion
echo "$(date +%s)" > "$TRACKER_DIR/metadata/${SESSION_ID}_completed"

# Cleanup metadata after 7 days
find "$TRACKER_DIR/metadata" -name "*.json" -mtime +7 -delete 2>/dev/null || true
